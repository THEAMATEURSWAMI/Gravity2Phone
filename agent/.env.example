# Copy this file to .env and fill in your values

# ===== SECURITY =====
# A long, random, secret string. Your mobile app must send this in every request.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
API_SECRET_TOKEN=your_super_secret_token_here

# ===== NETWORK =====
# The host to bind to. Use 0.0.0.0 to allow all interfaces,
# or your Tailscale IP (e.g. 100.x.x.x) to restrict to VPN only.
AGENT_HOST=0.0.0.0
AGENT_PORT=8742

# ===== SHELL =====
# The shell to use for executing commands (bash, zsh, sh, powershell)
AGENT_SHELL=bash

# ===== FIREBASE (Phase 2 - leave empty for Phase 1) =====
FIREBASE_SERVICE_ACCOUNT_PATH=
